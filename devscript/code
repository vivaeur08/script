local function BuildESP(player)
    if player == LocalPlayer then return end

    local function onChar(character)
        if not getgenv().DevHub.Active or not getgenv().DevHub.States.ESPPlayers then return end

        -- Supprimer l'ancien ESP
        local old = getgenv().DevHub.ESPObjects[player.Name]
        if old then pcall(function() old:Destroy() end) end

        local hrp = character:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "ESP_" .. player.Name
        gui.Adornee = hrp
        gui.Size = UDim2.new(4, 0, 5.5, 0)
        gui.StudsOffset = Vector3.new(0, 1, 0)
        gui.AlwaysOnTop = true
        gui.Parent = CoreGui

        -- Box
        local box = Instance.new("Frame")
        box.Size = UDim2.new(1, 0, 1, 0)
        box.BackgroundTransparency = 1
        box.Parent = gui
        AddStroke(box, Color3.fromRGB(255, 50, 50), 2, 0.25)
        AddCorner(box, 3)

        -- Nom
        local nm = Instance.new("TextLabel")
        nm.Size = UDim2.new(1, 0, 0.1, 0)
        nm.Position = UDim2.new(0, 0, -0.12, 0)
        nm.BackgroundTransparency = 1
        nm.Text = player.Name
        nm.TextColor3 = Color3.new(1, 1, 1)
        nm.TextStrokeTransparency = 0.5
        nm.TextStrokeColor3 = Color3.new(0, 0, 0)
        nm.TextSize = 14
        nm.Font = Enum.Font.GothamBold
        nm.Parent = gui

        -- Distance
        local dist = Instance.new("TextLabel")
        dist.Size = UDim2.new(1, 0, 0.08, 0)
        dist.Position = UDim2.new(0, 0, 1.02, 0)
        dist.BackgroundTransparency = 1
        dist.Text = "0m"
        dist.TextColor3 = Color3.fromRGB(200, 200, 200)
        dist.TextStrokeTransparency = 0.6
        dist.TextStrokeColor3 = Color3.new(0, 0, 0)
        dist.TextSize = 12
        dist.Font = Enum.Font.GothamMedium
        dist.Parent = gui

        -- Barre de vie
        local hpBg = Instance.new("Frame")
        hpBg.Size = UDim2.new(0.04, 0, 1, 0)
        hpBg.Position = UDim2.new(-0.07, 0, 0, 0)
        hpBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        hpBg.BackgroundTransparency = 0.3
        hpBg.Parent = gui
        AddCorner(hpBg, 2)

        local hpFill = Instance.new("Frame")
        hpFill.Size = UDim2.new(1, 0, 1, 0)
        hpFill.AnchorPoint = Vector2.new(0, 1)
        hpFill.Position = UDim2.new(0, 0, 1, 0)
        hpFill.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
        hpFill.Parent = hpBg
        AddCorner(hpFill, 2)

        getgenv().DevHub.ESPObjects[player.Name] = gui

        -- Boucle mise à jour
        task.spawn(function()
            while gui and gui.Parent and getgenv().DevHub.Active and getgenv().DevHub.States.ESPPlayers do
                pcall(function()
                    local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    local theirHrp = character and character:FindFirstChild("HumanoidRootPart")
                    if myHrp and theirHrp then
                        dist.Text = math.floor((myHrp.Position - theirHrp.Position).Magnitude) .. "m"
                    end
                    local hum = character and character:FindFirstChild("Humanoid")
                    if hum then
                        local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        hpFill.Size = UDim2.new(1, 0, pct, 0)
                        hpFill.BackgroundColor3 = Color3.fromRGB(255 * (1 - pct), 255 * pct, 50)
                    end
                end)
                task.wait(0.15)
            end
            if gui and gui.Parent then gui:Destroy() end
        end)
    end

    if player.Character then onChar(player.Character) end
    Connect(player.CharacterAdded, onChar)
end

-- Observer les joueurs pour l'ESP
Connect(Players.PlayerAdded, function(plr)
    if getgenv().DevHub.States.ESPPlayers then
        BuildESP(plr)
    end
end)

Connect(Players.PlayerRemoving, function(plr)
    local obj = getgenv().DevHub.ESPObjects[plr.Name]
    if obj then pcall(function() obj:Destroy() end) end
    getgenv().DevHub.ESPObjects[plr.Name] = nil
end)

-- Boucle de vérification ESP on/off
task.spawn(function()
    local wasOn = false
    while getgenv().DevHub.Active do
        local isOn = getgenv().DevHub.States.ESPPlayers
        if isOn and not wasOn then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer then BuildESP(plr) end
            end
        elseif not isOn and wasOn then
            for k, obj in pairs(getgenv().DevHub.ESPObjects) do
                pcall(function() obj:Destroy() end)
            end
            getgenv().DevHub.ESPObjects = {}
        end
        wasOn = isOn
        task.wait(0.5)
    end
end)

-- 14.5 : Click-to-TP
Connect(Mouse.Button1Down, function()
    if not getgenv().DevHub.Active then return end
    if not getgenv().DevHub.States.ClickToTP then return end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) or
       UserInputService:IsKeyDown(Enum.KeyCode.RightControl) then
        pcall(function()
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local hit = Mouse.Hit
                hrp.CFrame = hit + Vector3.new(0, 3, 0)
                ShowNotification("Téléporté !", string.format("(%.1f, %.1f, %.1f)", hit.X, hit.Y, hit.Z), Theme.Success, 2)
            end
        end)
    end
end)

-- 14.6 : Mise à jour temps réel (RenderStepped)
local frameCount = 0
local lastFpsTime = tick()
local currentFps = 0

Connect(RunService.RenderStepped, function()
    if not getgenv().DevHub.Active then return end

    -- FPS
    frameCount = frameCount + 1
    local now = tick()
    if now - lastFpsTime >= 1 then
        currentFps = frameCount
        frameCount = 0
        lastFpsTime = now
    end

    -- Stats (seulement si l'onglet est visible)
    if CurrentTab == "Stats" then
        fpsDisp.Text = tostring(currentFps)
        fpsDisp.TextColor3 = currentFps >= 50 and Theme.Success or (currentFps >= 30 and Theme.Warning or Theme.Danger)

        pcall(function()
            local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
            pingDisp.Text = ping .. " ms"
            pingDisp.TextColor3 = ping <= 80 and Theme.Success or (ping <= 150 and Theme.Warning or Theme.Danger)
        end)

        playersDisp.Text = #Players:GetPlayers() .. "/" .. Players.MaxPlayers
        local jid = game.JobId
        serverDisp.Text = #jid > 18 and (jid:sub(1, 18) .. "...") or jid
    end

    -- Coordonnées (seulement si l'onglet Teleport est visible)
    if CurrentTab == "Teleport" then
        pcall(function()
            local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local p = hrp.Position
                xDisp.Text = string.format("%.2f", p.X)
                yDisp.Text = string.format("%.2f", p.Y)
                zDisp.Text = string.format("%.2f", p.Z)
            end
        end)
    end
end)

-- 14.7 : Hitboxes (mise à jour périodique)
task.spawn(function()
    while getgenv().DevHub.Active do
        if getgenv().DevHub.States.ShowHitboxes then
            pcall(function()
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= LocalPlayer and plr.Character then
                        for _, part in ipairs(plr.Character:GetDescendants()) do
                            if part:IsA("BasePart") then
                                if part.Name == "Head" then
                                    part.Size = Vector3.new(2, 2, 2)
                                    part.Transparency = 0.5
                                    part.Material = Enum.Material.ForceField
                                    part.Color = Color3.fromRGB(255, 50, 50)
                                    part.CanCollide = false
                                elseif part.Name == "HumanoidRootPart" then
                                    part.Transparency = 0.7
                                    part.Material = Enum.Material.ForceField
                                    part.Color = Color3.fromRGB(50, 50, 255)
                                end
                            end
                        end
                    end
                end
            end)
        end
        task.wait(1)
    end
end)

-- 14.8 : Réappliquer walkspeed/jumppower si reset par le jeu
task.spawn(function()
    while getgenv().DevHub.Active do
        pcall(function()
            local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then
                local ws = getgenv().DevHub.States.WalkSpeed
                local jp = getgenv().DevHub.States.JumpPower
                if ws and ws ~= 16 and hum.WalkSpeed ~= ws then
                    hum.WalkSpeed = ws
                end
                if jp and jp ~= 50 and hum.JumpPower ~= jp then
                    hum.UseJumpPower = true
                    hum.JumpPower = jp
                end
            end
        end)
        task.wait(0.8)
    end
end)

