-- LOGIQUE : ESP (avec nom du joueur)
-- ============================================
local function buildESP(plr)
    if plr == LP then return end
    local function onChar(char)
        if not getgenv().DH.On or not getgenv().DH.S.ESPOn then return end
        local old = getgenv().DH.ESP[plr.Name]
        if old then pcall(function() old:Destroy() end) end

        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local gui = Instance.new("BillboardGui")
        gui.Name = "ESP_" .. plr.Name
        gui.Adornee = hrp
        gui.Size = UDim2.new(4, 0, 5.5, 0)
        gui.StudsOffset = Vector3.new(0, 1, 0)
        gui.AlwaysOnTop = true
        gui.Parent = CoreGui

        -- Box ESP
        local box = Instance.new("Frame")
        box.Size = UDim2.new(1, 0, 1, 0)
        box.BackgroundTransparency = 1
        box.Parent = gui
        stroke(box, Color3.fromRGB(255, 50, 50), 2)
        corner(box, 3)

        -- Nom du joueur au-dessus de la box
        local nameTag = Instance.new("TextLabel")
        nameTag.Size = UDim2.new(1, 0, 0.1, 0)
        nameTag.Position = UDim2.new(0, 0, -0.13, 0)
        nameTag.BackgroundTransparency = 1
        nameTag.Text = plr.Name
        nameTag.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameTag.TextStrokeTransparency = 0.4
        nameTag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        nameTag.TextSize = 14
        nameTag.Font = Enum.Font.GothamBold
        nameTag.Parent = gui

        -- DisplayName en dessous si différent
        if plr.DisplayName ~= plr.Name then
            local dispTag = Instance.new("TextLabel")
            dispTag.Size = UDim2.new(1, 0, 0.07, 0)
            dispTag.Position = UDim2.new(0, 0, -0.05, 0)
            dispTag.BackgroundTransparency = 1
            dispTag.Text = "(" .. plr.DisplayName .. ")"
            dispTag.TextColor3 = Color3.fromRGB(180, 180, 220)
            dispTag.TextStrokeTransparency = 0.5
            dispTag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            dispTag.TextSize = 11
            dispTag.Font = Enum.Font.GothamMedium
            dispTag.Parent = gui
        end

        -- Distance en dessous de la box
        local distTag = Instance.new("TextLabel")
        distTag.Size = UDim2.new(1, 0, 0.08, 0)
        distTag.Position = UDim2.new(0, 0, 1.02, 0)
        distTag.BackgroundTransparency = 1
        distTag.Text = "0m"
        distTag.TextColor3 = Color3.fromRGB(200, 200, 200)
        distTag.TextStrokeTransparency = 0.5
        distTag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        distTag.TextSize = 12
        distTag.Font = Enum.Font.GothamMedium
        distTag.Parent = gui

        -- Barre de vie à gauche
        local hpBg = Instance.new("Frame")
        hpBg.Size = UDim2.new(0.04, 0, 1, 0)
        hpBg.Position = UDim2.new(-0.07, 0, 0, 0)
        hpBg.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        hpBg.BackgroundTransparency = 0.3
        hpBg.Parent = gui
        corner(hpBg, 2)

        local hpFill = Instance.new("Frame")
        hpFill.Size = UDim2.new(1, 0, 1, 0)
        hpFill.AnchorPoint = Vector2.new(0, 1)
        hpFill.Position = UDim2.new(0, 0, 1, 0)
        hpFill.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
        hpFill.Parent = hpBg
        corner(hpFill, 2)

        -- HP texte
        local hpText = Instance.new("TextLabel")
        hpText.Size = UDim2.new(1, 0, 0.07, 0)
        hpText.Position = UDim2.new(0, 0, 1.12, 0)
        hpText.BackgroundTransparency = 1
        hpText.Text = "100 HP"
        hpText.TextColor3 = Color3.fromRGB(80, 255, 80)
        hpText.TextStrokeTransparency = 0.5
        hpText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        hpText.TextSize = 10
        hpText.Font = Enum.Font.GothamBold
        hpText.Parent = gui

        getgenv().DH.ESP[plr.Name] = gui

        -- Boucle mise à jour distance + HP
        task.spawn(function()
            while gui and gui.Parent and getgenv().DH.On and getgenv().DH.S.ESPOn do
                pcall(function()
                    local my = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                    local th = char and char:FindFirstChild("HumanoidRootPart")
                    if my and th then
                        local d = math.floor((my.Position - th.Position).Magnitude)
                        distTag.Text = d .. "m"
                        -- Couleur distance
                        if d < 30 then
                            distTag.TextColor3 = Color3.fromRGB(255, 80, 80)
                        elseif d < 80 then
                            distTag.TextColor3 = Color3.fromRGB(255, 200, 80)
                        else
                            distTag.TextColor3 = Color3.fromRGB(180, 180, 200)
                        end
                    end
                    local hum = char and char:FindFirstChild("Humanoid")
                    if hum then
                        local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
                        hpFill.Size = UDim2.new(1, 0, pct, 0)
                        hpFill.BackgroundColor3 = Color3.fromRGB(255 * (1 - pct), 255 * pct, 50)
                        hpText.Text = math.floor(hum.Health) .. " HP"
                        hpText.TextColor3 = hpFill.BackgroundColor3
                    end
                end)
                task.wait(0.12)
            end
            if gui and gui.Parent then gui:Destroy() end
        end)
    end
    if plr.Character then onChar(plr.Character) end
    conn(plr.CharacterAdded, onChar)
end

