-- ============================================
-- UTILITAIRES
-- ============================================
local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = p
end

local function stroke(p, col, t)
    local s = Instance.new("UIStroke")
    s.Color = col or Color3.fromRGB(60, 60, 80)
    s.Thickness = t or 1
    s.Parent = p
end

local function tw(o, props, d)
    TweenService:Create(o, TweenInfo.new(d or 0.2, Enum.EasingStyle.Quint), props):Play()
end

local function conn(sig, cb)
    local c = sig:Connect(cb)
    table.insert(getgenv().DH.Conn, c)
    return c
end

-- ============================================
-- CRÉATION DE PANNEAU FLOTTANT
-- Chaque panneau a : réduire (par panneau), lock, close (par panneau)
-- ============================================
local function makePanel(name, icon, x, y, w, h, accentColor)
    local panel = Instance.new("Frame")
    panel.Name = "Panel_" .. name
    panel.Parent = SG
    panel.BackgroundColor3 = Color3.fromRGB(12, 12, 18)
    panel.Position = UDim2.new(0, x, 0, y)
    panel.Size = UDim2.new(0, w, 0, h)
    panel.Active = true
    panel.Draggable = true
    panel.ClipsDescendants = true
    corner(panel, 10)
    stroke(panel, accentColor or Color3.fromRGB(60, 60, 80), 1)

    -- Animation apparition
    panel.BackgroundTransparency = 1
    local targetSize = UDim2.new(0, w, 0, h)
    local targetPos = UDim2.new(0, x, 0, y)
    panel.Size = UDim2.new(0, 0, 0, 0)
    panel.Position = UDim2.new(0, x + w / 2, 0, y + h / 2)
    tw(panel, {
        BackgroundTransparency = 0,
        Size = targetSize,
        Position = targetPos
    }, 0.4)

    -- Barre de titre
    local bar = Instance.new("Frame")
    bar.Parent = panel
    bar.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
    bar.Size = UDim2.new(1, 0, 0, 30)
    bar.BorderSizePixel = 0
    corner(bar, 10)

    local barFix = Instance.new("Frame")
    barFix.Parent = bar
    barFix.BackgroundColor3 = Color3.fromRGB(18, 18, 25)
    barFix.Position = UDim2.new(0, 0, 1, -8)
    barFix.Size = UDim2.new(1, 0, 0, 8)
    barFix.BorderSizePixel = 0

    -- Icône
    local ico = Instance.new("TextLabel")
    ico.Parent = bar
    ico.BackgroundTransparency = 1
    ico.Position = UDim2.new(0, 8, 0, 0)
    ico.Size = UDim2.new(0, 22, 1, 0)
    ico.Font = Enum.Font.GothamBold
    ico.Text = icon
    ico.TextColor3 = accentColor or Color3.fromRGB(180, 180, 220)
    ico.TextSize = 13

    -- Titre
    local title = Instance.new("TextLabel")
    title.Parent = bar
    title.BackgroundTransparency = 1
    title.Position = UDim2.new(0, 30, 0, 0)
    title.Size = UDim2.new(1, -100, 1, 0)
    title.Font = Enum.Font.GothamBold
    title.Text = name
    title.TextColor3 = Color3.fromRGB(200, 200, 215)
    title.TextSize = 12
    title.TextXAlignment = Enum.TextXAlignment.Left

    -- === BOUTON MINIMIZE (par panneau) ===
    local minimized = false
    local originalH = h

    local minBtn = Instance.new("TextButton")
    minBtn.Parent = bar
    minBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
    minBtn.Position = UDim2.new(1, -72, 0.5, -9)
    minBtn.Size = UDim2.new(0, 18, 0, 18)
    minBtn.Font = Enum.Font.GothamBold
    minBtn.Text = "─"
    minBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
    minBtn.TextSize = 12
    minBtn.AutoButtonColor = false
    corner(minBtn, 4)

    minBtn.MouseEnter:Connect(function()
        tw(minBtn, {BackgroundColor3 = Color3.fromRGB(60, 60, 80)}, 0.12)
    end)
    minBtn.MouseLeave:Connect(function()
        tw(minBtn, {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}, 0.12)
    end)
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            minBtn.Text = "+"
            tw(panel, {Size = UDim2.new(0, w, 0, 30)}, 0.25)
        else
            minBtn.Text = "─"
            tw(panel, {Size = UDim2.new(0, w, 0, originalH)}, 0.25)
        end
    end)

    -- === BOUTON LOCK (cadenas) ===
    local locked = false

    local lockBtn = Instance.new("TextButton")
    lockBtn.Parent = bar
    lockBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 60)
    lockBtn.Position = UDim2.new(1, -50, 0.5, -9)
    lockBtn.Size = UDim2.new(0, 18, 0, 18)
    lockBtn.Font = Enum.Font.GothamBold
    lockBtn.Text = "🔓"
    lockBtn.TextColor3 = Color3.fromRGB(180, 180, 200)
    lockBtn.TextSize = 10
    lockBtn.AutoButtonColor = false
    corner(lockBtn, 4)

    lockBtn.MouseEnter:Connect(function()
        tw(lockBtn, {BackgroundColor3 = Color3.fromRGB(60, 60, 80)}, 0.12)
    end)
    lockBtn.MouseLeave:Connect(function()
        if locked then
            tw(lockBtn, {BackgroundColor3 = Color3.fromRGB(70, 50, 30)}, 0.12)
        else
            tw(lockBtn, {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}, 0.12)
        end
    end)
    lockBtn.MouseButton1Click:Connect(function()
        locked = not locked
        if locked then
            panel.Draggable = false
            lockBtn.Text = "🔒"
            tw(lockBtn, {BackgroundColor3 = Color3.fromRGB(70, 50, 30)}, 0.15)
            -- Petit flash pour confirmer
            tw(stroke, {}, 0)
        else
            panel.Draggable = true
            lockBtn.Text = "🔓"
            tw(lockBtn, {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}, 0.15)
        end
    end)

    -- === BOUTON CLOSE (par panneau) ===
    local closeBtn = Instance.new("TextButton")
    closeBtn.Parent = bar
    closeBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
    closeBtn.Position = UDim2.new(1, -28, 0.5, -9)
    closeBtn.Size = UDim2.new(0, 18, 0, 18)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.Text = "✖️"
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.TextSize = 10
    closeBtn.AutoButtonColor = false
    corner(closeBtn, 4)

    closeBtn.MouseEnter:Connect(function()
        tw(closeBtn, {BackgroundColor3 = Color3.fromRGB(220, 70, 70)}, 0.12)
    end)
    closeBtn.MouseLeave:Connect(function()
        tw(closeBtn, {BackgroundColor3 = Color3.fromRGB(180, 50, 50)}, 0.12)
    end)
    closeBtn.MouseButton1Click:Connect(function()
        -- Cache uniquement CE panneau
        tw(panel, {BackgroundTransparency = 1, Size = UDim2.new(0, 0, 0, 0)}, 0.25)
        task.wait(0.25)
        panel.Visible = false
        -- Remettre la taille pour pouvoir le réafficher
        panel.Size = targetSize
        panel.BackgroundTransparency = 0
    end)

    -- Séparateur
    local sep = Instance.new("Frame")
    sep.Parent = panel
    sep.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    sep.Position = UDim2.new(0.05, 0, 0, 30)
    sep.Size = UDim2.new(0.9, 0, 0, 1)
    sep.BorderSizePixel = 0

    -- Zone de contenu
    local content = Instance.new("Frame")
    content.Name = "Content"
    content.Parent = panel
    content.BackgroundTransparency = 1
    content.Position = UDim2.new(0, 0, 0, 35)
    content.Size = UDim2.new(1, 0, 1, -35)
    content.ClipsDescendants = true

    return panel, content
end

