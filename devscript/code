-- ESP watcher on/off
task.spawn(function()
    local was = false
    while getgenv().DH.On do
        local is = getgenv().DH.S.ESPOn
        if is and not was then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LP then buildESP(plr) end
            end
        elseif not is and was then
            for _, obj in pairs(getgenv().DH.ESP) do
                pcall(function() obj:Destroy() end)
            end
            getgenv().DH.ESP = {}
        end
        was = is
        task.wait(0.5)
    end
end)

