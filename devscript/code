local function ToggleMinimize()
    getgenv().DevHub.Minimized = not getgenv().DevHub.Minimized
    if getgenv().DevHub.Minimized then
        Tween(MainFrame, 0.35, {Size = UDim2.new(0, WINDOW_W, 0, TITLEBAR_H)})
        task.delay(0.12, function()
            ContentFrame.Visible = false
            NavFrame.Visible = false
            TitleLine.Visible = false
        end)
    else
        ContentFrame.Visible = true
        NavFrame.Visible = true
        TitleLine.Visible = true
        Tween(MainFrame, 0.35, {Size = UDim2.new(0, WINDOW_W, 0, WINDOW_H)})
    end
end

MinBtn.MouseButton1Click:Connect(ToggleMinimize)

CloseBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    ShowNotification("Interface cachée", "Appuyez sur RightShift pour réouvrir.", Theme.Warning, 3)
end)

-- Raccourci RightShift
Connect(UserInputService.InputBegan, function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        if not MainFrame.Visible then
            MainFrame.Visible = true
            MainFrame.BackgroundTransparency = 0.6
            Tween(MainFrame, 0.25, {BackgroundTransparency = 0.02})
        else
            ToggleMinimize()
        end
    end
end)

