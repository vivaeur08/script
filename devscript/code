-- ============================================
-- BOUCLE RENDER : FPS, COORDS, STATS
-- ============================================
local frameCount = 0
local lastFps = tick()
local curFps = 0

conn(RunService.RenderStepped, function()
    if not getgenv().DH.On then return end

    -- FPS
    frameCount = frameCount + 1
    local now = tick()
    if now - lastFps >= 1 then
        curFps = frameCount
        frameCount = 0
        lastFps = now
    end

    -- Stats panel
    fpsDisp.Text = tostring(curFps)
    fpsDisp.TextColor3 = curFps >= 50 and Color3.fromRGB(80, 200, 100)
        or (curFps >= 30 and Color3.fromRGB(250, 180, 50) or Color3.fromRGB(250, 70, 70))

    pcall(function()
        local ping = math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())
        pingDisp.Text = ping .. " ms"
        pingDisp.TextColor3 = ping <= 80 and Color3.fromRGB(80, 200, 100)
            or (ping <= 150 and Color3.fromRGB(250, 180, 50) or Color3.fromRGB(250, 70, 70))
    end)

    plrDisp.Text = #Players:GetPlayers() .. "/" .. Players.MaxPlayers
    local jid = game.JobId
    srvDisp.Text = #jid > 14 and (jid:sub(1, 14) .. "..") or jid

    -- Coordonnées
    pcall(function()
        local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local p = hrp.Position
            xDisp.Text = string.format("%.2f", p.X)
            yDisp.Text = string.format("%.2f", p.Y)
            zDisp.Text = string.format("%.2f", p.Z)
            fullVal.Text = string.format("%.2f, %.2f, %.2f", p.X, p.Y, p.Z)

            local spd = math.floor(hrp.AssemblyLinearVelocity.Magnitude)
            speedDisp.Text = spd .. " studs/s"
            speedDisp.TextColor3 = spd > 5 and Color3.fromRGB(100, 220, 120) or Color3.fromRGB(150, 80, 80)
        end
    end)

    -- ESP count
    local count = 0
    for _ in pairs(getgenv().DH.ESP) do count = count + 1 end
    espCount.Text = tostring(count)

    -- Réapplication WS/JP
    pcall(function()
        local h = LP.Character and LP.Character:FindFirstChild("Humanoid")
        if h then
            local ws = getgenv().DH.S.WS
            local jp = getgenv().DH.S.JP
            if ws and ws ~= 16 and h.WalkSpeed ~= ws then h.WalkSpeed = ws end
            if jp and jp ~= 50 and h.JumpPower ~= jp then
                h.UseJumpPower = true; h.JumpPower = jp
            end
        end
    end)
end)

