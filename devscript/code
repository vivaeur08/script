-- COMPOSANTS : TOGGLE
-- ============================================
local function makeToggle(parent, text, yPos, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    frame.Position = UDim2.new(0.05, 0, 0, yPos)
    frame.Size = UDim2.new(0.9, 0, 0, 30)
    corner(frame, 6)
    stroke(frame, Color3.fromRGB(45, 45, 60), 1)

    local lbl = Instance.new("TextLabel")
    lbl.Parent = frame
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 10, 0, 0)
    lbl.Size = UDim2.new(1, -55, 1, 0)
    lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(195, 195, 210)
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.TextTruncate = Enum.TextTruncate.AtEnd

    local bg = Instance.new("Frame")
    bg.Parent = frame
    bg.BackgroundColor3 = default and Color3.fromRGB(90, 110, 255) or Color3.fromRGB(45, 45, 60)
    bg.Position = UDim2.new(1, -42, 0.5, -8)
    bg.Size = UDim2.new(0, 32, 0, 16)
    corner(bg, 8)

    local cir = Instance.new("Frame")
    cir.Parent = bg
    cir.BackgroundColor3 = Color3.fromRGB(240, 240, 240)
    cir.Size = UDim2.new(0, 12, 0, 12)
    cir.Position = default and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
    corner(cir, 6)

    local enabled = default or false

    local btn = Instance.new("TextButton")
    btn.Parent = frame
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text = ""

    btn.MouseEnter:Connect(function()
        tw(frame, {BackgroundColor3 = Color3.fromRGB(28, 28, 38)}, 0.12)
    end)
    btn.MouseLeave:Connect(function()
        tw(frame, {BackgroundColor3 = Color3.fromRGB(20, 20, 28)}, 0.12)
    end)
    btn.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            tw(bg, {BackgroundColor3 = Color3.fromRGB(90, 110, 255)}, 0.18)
            tw(cir, {Position = UDim2.new(1, -14, 0.5, -6)}, 0.18)
        else
            tw(bg, {BackgroundColor3 = Color3.fromRGB(45, 45, 60)}, 0.18)
            tw(cir, {Position = UDim2.new(0, 2, 0.5, -6)}, 0.18)
        end
        if callback then callback(enabled) end
    end)

    return frame
end

-- ============================================
-- COMPOSANTS : SLIDER
-- ============================================
local function makeSlider(parent, text, yPos, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 28)
    frame.Position = UDim2.new(0.05, 0, 0, yPos)
    frame.Size = UDim2.new(0.9, 0, 0, 42)
    corner(frame, 6)
    stroke(frame, Color3.fromRGB(45, 45, 60), 1)

    local lbl = Instance.new("TextLabel")
    lbl.Parent = frame
    lbl.BackgroundTransparency = 1
    lbl.Position = UDim2.new(0, 10, 0, 3)
    lbl.Size = UDim2.new(1, -60, 0, 16)
    lbl.Font = Enum.Font.GothamMedium
    lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(195, 195, 210)
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local val = Instance.new("TextLabel")
    val.Parent = frame
    val.BackgroundTransparency = 1
    val.Position = UDim2.new(1, -50, 0, 3)
    val.Size = UDim2.new(0, 40, 0, 16)
    val.Font = Enum.Font.GothamBold
    val.Text = tostring(default)
    val.TextColor3 = Color3.fromRGB(100, 120, 255)
    val.TextSize = 11
    val.TextXAlignment = Enum.TextXAlignment.Right

    local track = Instance.new("Frame")
    track.Parent = frame
    track.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    track.Position = UDim2.new(0, 10, 0, 27)
    track.Size = UDim2.new(1, -20, 0, 5)
    corner(track, 3)

    local frac = math.clamp((default - min) / (max - min), 0, 1)

    local fill = Instance.new("Frame")
    fill.Parent = track
    fill.BackgroundColor3 = Color3.fromRGB(90, 110, 255)
    fill.Size = UDim2.new(frac, 0, 1, 0)
    corner(fill, 3)

    local knob = Instance.new("Frame")
    knob.Parent = track
    knob.BackgroundColor3 = Color3.fromRGB(230, 230, 240)
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.Position = UDim2.new(frac, -6, 0.5, -6)
    corner(knob, 6)

    local sliding = false
    local curVal = default

    local hitbox = Instance.new("TextButton")
    hitbox.Parent = frame
    hitbox.Size = UDim2.new(1, -20, 0, 18)
    hitbox.Position = UDim2.new(0, 10, 0, 22)
    hitbox.BackgroundTransparency = 1
    hitbox.Text = ""

    local function update(inputX)
        local ax = track.AbsolutePosition.X
        local aw = track.AbsoluteSize.X
        local f = math.clamp((inputX - ax) / aw, 0, 1)
        curVal = math.floor(min + (max - min) * f)
        val.Text = tostring(curVal)
        fill.Size = UDim2.new(f, 0, 1, 0)
        knob.Position = UDim2.new(f, -6, 0.5, -6)
        if callback then callback(curVal) end
    end

    hitbox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = true
            update(input.Position.X)
        end
    end)
    hitbox.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)
    conn(UserInputService.InputChanged, function(input)
        if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input.Position.X)
        end
    end)

    return frame
end

-- ============================================
-- COMPOSANTS : BOUTON
-- ============================================
local function makeButton(parent, text, yPos, color, callback)
    local btn = Instance.new("TextButton")
    btn.Parent = parent
    btn.BackgroundColor3 = color or Color3.fromRGB(90, 110, 255)
    btn.BackgroundTransparency = 0.3
    btn.Position = UDim2.new(0.05, 0, 0, yPos)
    btn.Size = UDim2.new(0.9, 0, 0, 28)
    btn.Font = Enum.Font.GothamBold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(220, 220, 235)
    btn.TextSize = 11
    btn.AutoButtonColor = false
    corner(btn, 6)
    stroke(btn, color or Color3.fromRGB(90, 110, 255), 1)

    btn.MouseEnter:Connect(function()
        tw(btn, {BackgroundTransparency = 0.1}, 0.12)
    end)
    btn.MouseLeave:Connect(function()
        tw(btn, {BackgroundTransparency = 0.3}, 0.12)
    end)
    btn.MouseButton1Click:Connect(function()
        tw(btn, {BackgroundTransparency = 0.5}, 0.06)
        task.wait(0.06)
        tw(btn, {BackgroundTransparency = 0.1}, 0.06)
        if callback then callback() end
    end)
    return btn
end

