-- Créer le contenu scrollable d'un onglet
local function MakeTabContent(name)
    local scroll = Instance.new("ScrollingFrame")
    scroll.Name = "Tab_" .. name
    scroll.Size = UDim2.new(1, 0, 1, 0)
    scroll.Position = UDim2.new(0, 0, 0, 0)
    scroll.BackgroundTransparency = 1
    scroll.BorderSizePixel = 0
    scroll.ScrollBarThickness = 3
    scroll.ScrollBarImageColor3 = Theme.Accent
    scroll.ScrollBarImageTransparency = 0.4
    scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    scroll.Visible = false
    scroll.ZIndex = 6
    scroll.Parent = ContentFrame

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = scroll

    AddPadding(scroll, 12, 16, 16, 16)

    -- Auto-resize canvas
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 35)
    end)

    return scroll
end

-- Changer d'onglet
local function SwitchTab(name)
    if CurrentTab == name then return end

    -- Désactiver l'ancien
    if CurrentTab and Tabs[CurrentTab] then
        local old = Tabs[CurrentTab]
        Tween(old.Nav.Button, 0.2, {BackgroundTransparency = 1})
        Tween(old.Nav.NameLabel, 0.2, {TextColor3 = Theme.TextSecondary})
        Tween(old.Nav.IconLabel, 0.2, {TextColor3 = Theme.TextMuted})
        Tween(old.Nav.Indicator, 0.2, {BackgroundTransparency = 1})
        old.Content.Visible = false
    end

    CurrentTab = name
    local new = Tabs[name]
    Tween(new.Nav.Button, 0.2, {BackgroundTransparency = 0.7})
    Tween(new.Nav.NameLabel, 0.2, {TextColor3 = Theme.Text})
    Tween(new.Nav.IconLabel, 0.2, {TextColor3 = Theme.Accent})
    Tween(new.Nav.Indicator, 0.2, {BackgroundTransparency = 0})
    new.Content.Visible = true
end

-- Instancier tous les onglets
for _, def in ipairs(TabDefs) do
    local nav = MakeNavButton(def)
    local content = MakeTabContent(def.Name)

    Tabs[def.Name] = {
        Nav = nav,
        Content = content,
    }

    -- Hover
    nav.Button.MouseEnter:Connect(function()
        if CurrentTab ~= def.Name then
            Tween(nav.Button, 0.12, {BackgroundTransparency = 0.85})
        end
    end)
    nav.Button.MouseLeave:Connect(function()
        if CurrentTab ~= def.Name then
            Tween(nav.Button, 0.12, {BackgroundTransparency = 1})
        end
    end)

    -- Clic
    nav.Button.MouseButton1Click:Connect(function()
        SwitchTab(def.Name)
    end)
end

