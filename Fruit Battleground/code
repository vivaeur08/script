local function getHoldTimeForKey(keyStr)
    keyStr = string.upper(tostring(keyStr))
    if CustomHoldTimes[keyStr] and type(CustomHoldTimes[keyStr]) == "number" and CustomHoldTimes[keyStr] > 0 then
        return CustomHoldTimes[keyStr]
    end
    return KeybindHoldTime
end

local function simulateKeyAndClick(kc, keyStr)
