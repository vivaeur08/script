local function createESP()
    if ESPFolder then ESPFolder:Destroy() end
    ESPFolder = Instance.new("Folder")
    ESPFolder.Name = "FBG_ESP"
    ESPFolder.Parent = game.CoreGui

    local function clearAllESP()
        local cf = workspace:FindFirstChild("Characters")
        if cf then
            local pf = cf:FindFirstChild("Players")
            if pf then
                for _, char in ipairs(pf:GetChildren()) do
                    if char:FindFirstChild("FBG_ESP_GUI") then char.FBG_ESP_GUI:Destroy() end
                    if char:FindFirstChild("FBG_ESP_HL") then char.FBG_ESP_HL:Destroy() end
                end
            end
        end
    end

    local function addESP(character, playerName)
        if not character or not character:FindFirstChild("HumanoidRootPart") then return end
        if character:FindFirstChild("FBG_ESP_GUI") then character.FBG_ESP_GUI:Destroy() end
        if character:FindFirstChild("FBG_ESP_HL") then character.FBG_ESP_HL:Destroy() end

        local bb = Instance.new("BillboardGui")
        bb.Name = "FBG_ESP_GUI"
        bb.Parent = character
        bb.Adornee = character:FindFirstChild("HumanoidRootPart")
        bb.Size = UDim2.new(0, 200, 0, 50)
        bb.StudsOffset = Vector3.new(0, 3, 0)
        bb.AlwaysOnTop = true
        bb.MaxDistance = 10000

        local nameLabel = Instance.new("TextLabel")
        nameLabel.Parent = bb
        nameLabel.BackgroundTransparency = 1
        nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.Text = playerName
        nameLabel.TextColor3 = CurrentTheme.accent
        nameLabel.TextSize = 14
        nameLabel.TextStrokeTransparency = 0.3
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

        local distLabel = Instance.new("TextLabel")
        distLabel.Parent = bb
        distLabel.BackgroundTransparency = 1
        distLabel.Position = UDim2.new(0, 0, 0.5, 0)
        distLabel.Size = UDim2.new(1, 0, 0.5, 0)
        distLabel.Font = Enum.Font.Gotham
        distLabel.Text = "0m"
        distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        distLabel.TextSize = 11
        distLabel.TextStrokeTransparency = 0.5
        distLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

        local hl = Instance.new("Highlight")
        hl.Name = "FBG_ESP_HL"
        hl.Parent = character
        hl.FillColor = CurrentTheme.accent
        hl.FillTransparency = 0.7
        hl.OutlineColor = CurrentTheme.accent
        hl.OutlineTransparency = 0.3
    end

    local function refreshAllESP()
        local cf = workspace:FindFirstChild("Characters")
        if not cf then return end
        local pf = cf:FindFirstChild("Players")
        if not pf then return end
        for _, char in ipairs(pf:GetChildren()) do
            if char.Name ~= LocalPlayer.Name then
                addESP(char, char.Name)
            end
        end
    end

    refreshAllESP()

    local charFolder = workspace:FindFirstChild("Characters")
    if charFolder then
        local pf = charFolder:FindFirstChild("Players")
        if pf then
            pf.ChildAdded:Connect(function(child)
                task.wait(1)
                if ESPEnabled and child.Name ~= LocalPlayer.Name then
                    addESP(child, child.Name)
                end
            end)
        end
    end

    if ESPUpdateConnection then ESPUpdateConnection:Disconnect() end
    local espCounter = 0
    ESPUpdateConnection = RunService.Heartbeat:Connect(function()
        if not ESPEnabled then return end
        espCounter = espCounter + 1

        if espCounter >= 30 then
            espCounter = 0
            local cf = workspace:FindFirstChild("Characters")
            if cf then
                local pf = cf:FindFirstChild("Players")
                if pf then
                    for _, char in ipairs(pf:GetChildren()) do
                        if char.Name ~= LocalPlayer.Name then
                            local bb = char:FindFirstChild("FBG_ESP_GUI")
                            local hl = char:FindFirstChild("FBG_ESP_HL")

                            if not bb or not hl then
                                addESP(char, char.Name)
                            else
                                if hl then
                                    hl.FillColor = CurrentTheme.accent
                                    hl.OutlineColor = CurrentTheme.accent
                                end
                                local nameL = bb:FindFirstChildOfClass("TextLabel")
                                if nameL then
                                    nameL.TextColor3 = CurrentTheme.accent
                                end
                            end

                            if bb then
                                local myChar = getMyCharacter()
                                if myChar and myChar:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("HumanoidRootPart") then
                                    local dist = (myChar.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                                    for _, child in ipairs(bb:GetChildren()) do
                                        if child:IsA("TextLabel") and child.Position.Y.Scale >= 0.5 then
                                            child.Text = math.floor(dist) .. "m"
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
