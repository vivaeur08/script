local function makeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function makeStroke(parent, color, thickness, category)
    local s = Instance.new("UIStroke")
    s.Color = color or CurrentTheme.stroke
    s.Thickness = thickness or 1
    s.Parent = parent
    if category then registerThemed(category, s, "Color") end
    return s
end

local function tween(obj, props, duration)
    TweenService:Create(obj, TweenInfo.new(duration or 0.2), props):Play()
end

local function hoverEffect(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function() tween(btn, {BackgroundColor3 = hoverColor}, 0.15) end)
    btn.MouseLeave:Connect(function() tween(btn, {BackgroundColor3 = normalColor}, 0.15) end)
end

local function getMyCharacter()
    local char = nil
    local cf = workspace:FindFirstChild("Characters")
    if cf then
        local pf = cf:FindFirstChild("Players")
        if pf then char = pf:FindFirstChild(LocalPlayer.Name) end
    end
    if not char then char = LocalPlayer.Character end
    return char
end

local function teleportTo(x, y, z)
    local myChar = getMyCharacter()
    if myChar and myChar:FindFirstChild("HumanoidRootPart") then
        myChar.HumanoidRootPart.CFrame = CFrame.new(x, y, z)
        return true
    end
    return false
end

