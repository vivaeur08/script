local function saveSettings()
    pcall(function()
        if not isfolder(SETTINGS_FOLDER) then makefolder(SETTINGS_FOLDER) end
        writefile(SETTINGS_FILE, HttpService:JSONEncode({
            theme=CurrentThemeName,
            transparency=CurrentTransparency,
            webhook=WebhookURL,
            customHolds=CustomHoldTimes,
            toggleKey=getKeyName(ToggleKeyCode),
            tpPlayerKey=getKeyName(TPToPlayerKeyCode),
            espOptions=ESPOptions,
            blacklistedKeys=BlacklistedKeys,
            customMacros=CustomMacros
        }))
    end)
end

local function loadSettings()
    local s,r=pcall(function() if isfile(SETTINGS_FILE) then return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end return nil end)
    if s and r then return r end return nil
end

