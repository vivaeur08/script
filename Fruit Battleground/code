local function getAllFruits(playerName)
    local fl={}
    pcall(function()
        local p=Players:FindFirstChild(playerName)
        if p then
            local md=p:FindFirstChild("MAIN_DATA")
            if md then
                local fruits=md:FindFirstChild("Fruits")
                if fruits then
                    for _,ff in ipairs(fruits:GetChildren()) do
                        local lvl=nil
                        local lo=ff:FindFirstChild("Level")
                        if lo then
                            if lo:IsA("NumberValue") or lo:IsA("IntValue") then
                                lvl=lo.Value
                            else
                                for _,child in ipairs(lo:GetChildren()) do
                                    if child:IsA("NumberValue") or child:IsA("IntValue") then
                                        lvl=child.Value
                                        break
                                    end
                                end
                            end
                        end
                        table.insert(fl,{name=ff.Name,level=lvl or 0})
                    end
                end
            end
        end
    end)
    table.sort(fl,function(a,b) return (a.level or 0)>(b.level or 0) end)
    return fl
end

