local function sendWebhook(message)
    if WebhookURL == "" or #WebhookURL < 20 then return end
    local now = tick()
    if now - LastWebhookSent < 10 then return end
    if WebhookDebounce then return end
    WebhookDebounce = true
    LastWebhookSent = now
    task.spawn(function()
        pcall(function()
            local req = (syn and syn.request) or (http and http.request) or http_request or request
            if req then req({Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = HttpService:JSONEncode({content = message})}) end
        end)
        task.wait(10)
        WebhookDebounce = false
    end)
end

