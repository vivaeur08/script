local function startBossSpawn()
    createBossBar()
    if BossSpawnConnection then BossSpawnConnection:Disconnect() end
    BossSpawnConnection = RunService.Heartbeat:Connect(function()
        if not BossSpawnActive then return end
        pcall(function()
            local chars = workspace:FindFirstChild("Characters")
            if not chars then return end
            local npcs = chars:FindFirstChild("NPCs")
            if not npcs then return end
            local foundBoss = nil
            local foundHum = nil
            for _, npc in ipairs(npcs:GetChildren()) do
                if npc:IsA("Model") then
                    local hum = npc:FindFirstChildOfClass("Humanoid")
                    if hum and hum.Health > 0 and hum.MaxHealth >= 500 then
                        foundBoss = npc
                        foundHum = hum
                        break
                    end
                end
            end
            if foundBoss and foundHum and BossBarGui then
                BossBarGui.Visible = true
                local bossNameL = BossBarGui:FindFirstChild("BossName")
                if bossNameL then bossNameL.Text = "👹 " .. foundBoss.Name end
                local barBg = BossBarGui:FindFirstChild("BarBg")
                if barBg then
                    local barFill = barBg:FindFirstChild("BarFill")
                    local hpText = barBg:FindFirstChild("HPText")
                    if barFill and foundHum.MaxHealth > 0 then
                        local pct = math.clamp(foundHum.Health / foundHum.MaxHealth, 0, 1)
                        barFill.Size = UDim2.new(pct, 0, 1, 0)
                        if pct >= 0.6 then
                            barFill.BackgroundColor3 = Color3.fromRGB(80, 255, 80)
                        elseif pct >= 0.4 then
                            barFill.BackgroundColor3 = Color3.fromRGB(255, 220, 80)
                        else
                            barFill.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
                        end
                        if hpText then
                            if pct < 0.4 then
                                hpText.TextColor3 = Color3.fromRGB(255, 255, 255)
                            else
                                hpText.TextColor3 = Color3.fromRGB(0, 0, 0)
                            end
                        end
                    end
                    if hpText then
                        hpText.Text = math.floor(foundHum.Health) .. " / " .. math.floor(foundHum.MaxHealth)
                    end
                end
            else
                if BossBarGui then BossBarGui.Visible = false end
            end
        end)
    end)
end

local function stopBossSpawn()
    if BossSpawnConnection then BossSpawnConnection:Disconnect() BossSpawnConnection = nil end
    if BossBarGui then BossBarGui.Visible = false end
end

local function checkV2Requirements()
    local result = {eligible=false,kaidoKills=0,titles=0,fruitLevel=0,needed={}}
    pcall(function()
        local md = LocalPlayer:FindFirstChild("MAIN_DATA")
        if not md then return end
        local kk = md:FindFirstChild("KaidoKills")
        if kk then result.kaidoKills = kk.Value end
        local tt = md:FindFirstChild("Titles")
        if tt then result.titles = #tt:GetChildren() end
        local fruitName = getMyFruitName()
        if fruitName and fruitName ~= "???" then
            local lvl = getPlayerFruitLevel(LocalPlayer.Name, fruitName)
            if lvl then result.fruitLevel = lvl end
        end
        if result.kaidoKills < 5 then table.insert(result.needed, "Kaido x" .. (5 - result.kaidoKills)) end
        if result.titles < 30 then table.insert(result.needed, "Titles: " .. result.titles .. "/30") end
        if result.fruitLevel < 300 then table.insert(result.needed, "Fruit Lvl: " .. result.fruitLevel .. "/300") end
        if #result.needed == 0 then result.eligible = true end
    end)
    return result
end

