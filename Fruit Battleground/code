local SETTINGS_FOLDER = "FruitHUB"
local SETTINGS_FILE = SETTINGS_FOLDER .. "/settings.json"

local function saveSettings()
    pcall(function()
        if not isfolder(SETTINGS_FOLDER) then makefolder(SETTINGS_FOLDER) end
        local t = "Noir & Gris"
        if CurrentThemeName and type(CurrentThemeName) == "string" and Themes[CurrentThemeName] then t = CurrentThemeName end
        writefile(SETTINGS_FILE, HttpService:JSONEncode({theme=t, transparency=CurrentTransparency or 0, webhook=WebhookURL or "", customHolds=CustomHoldTimes or {}}))
    end)
end

local function loadSettings()
    local s,r = pcall(function() if isfile(SETTINGS_FILE) then return HttpService:JSONDecode(readfile(SETTINGS_FILE)) end return nil end)
    if s and r then return r end return nil
end

local ss = loadSettings()
if ss then
    if ss.theme and type(ss.theme) == "string" and Themes[ss.theme] then CurrentThemeName = ss.theme CurrentTheme = Themes[CurrentThemeName] end
    if ss.transparency and type(ss.transparency) == "number" then CurrentTransparency = math.clamp(ss.transparency, 0, 1) end
    if ss.webhook and type(ss.webhook) == "string" then WebhookURL = ss.webhook end
    if ss.customHolds and type(ss.customHolds) == "table" then CustomHoldTimes = ss.customHolds end
else saveSettings() end

local function applyTheme(tn, d)
    d = d or 0.4
    if not tn or not Themes[tn] then return end
    CurrentThemeName = tn CurrentTheme = Themes[tn]
    for cat, els in pairs(ThemedElements) do local col = CurrentTheme[cat]
        if col then for _, dt in ipairs(els) do if dt.element and dt.element.Parent then
            local p = {} p[dt.property] = col
            TweenService:Create(dt.element, TweenInfo.new(d, Enum.EasingStyle.Quad), p):Play()
        end end end
    end
    task.delay(0.1, saveSettings)
end

local function applyTransparency(v)
    CurrentTransparency = math.clamp(v, 0, 1)
    local lvl = {bg=1, content=0.8, sidebar=0.7, titleBar=0.5, card=0.6}
    for cat, m in pairs(lvl) do for _, dt in ipairs(ThemedElements[cat]) do
        if dt.element and dt.element.Parent and dt.property == "BackgroundColor3" then
            TweenService:Create(dt.element, TweenInfo.new(0.2), {BackgroundTransparency = v * m}):Play()
        end
    end end
    task.delay(0.1, saveSettings)
end

