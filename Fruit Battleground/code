            for tn, data in pairs(themeButtons) do
                if tn == CurrentThemeName then
                    data.activeLabel.Text = "✅ Actif"
                    data.activeLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
                    data.applyBtn.Text = "✅"
                    data.applyBtn.BackgroundColor3 = Color3.fromRGB(40, 80, 50)
                else
                    data.activeLabel.Text = "Cliquer pour appliquer"
                    data.activeLabel.TextColor3 = Color3.fromRGB(90, 90, 90)
                    data.applyBtn.Text = "Appliquer"
                    data.applyBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 60)
                end
            end
        end
        for _, themeInfo in ipairs(themeList) do
            local tBtn = Instance.new("TextButton")
            tBtn.Parent = SFrame
            tBtn.BackgroundColor3 = CurrentTheme.card
            tBtn.Size = UDim2.new(1, -10, 0, 50)
            tBtn.Font = Enum.Font.GothamBold
            tBtn.Text = ""
            tBtn.LayoutOrder = themeOrder
            tBtn.AutoButtonColor = false
            makeCorner(tBtn, 8)
            registerThemed("card", tBtn)
            local prev1 = Instance.new("Frame")
            prev1.Parent = tBtn
            prev1.BackgroundColor3 = themeInfo.preview1
            prev1.Position = UDim2.new(0, 10, 0.5, -15)
            prev1.Size = UDim2.new(0, 30, 0, 30)
            makeCorner(prev1, 6)
            makeStroke(prev1, themeInfo.preview2, 2)
            local prev2 = Instance.new("Frame")
            prev2.Parent = tBtn
            prev2.BackgroundColor3 = themeInfo.preview2
            prev2.Position = UDim2.new(0, 48, 0.5, -10)
            prev2.Size = UDim2.new(0, 20, 0, 20)
            makeCorner(prev2, 4)
            local tName = Instance.new("TextLabel")
            tName.Parent = tBtn
            tName.BackgroundTransparency = 1
            tName.Position = UDim2.new(0, 78, 0, 5)
            tName.Size = UDim2.new(1, -130, 0, 20)
            tName.Font = Enum.Font.GothamBold
            tName.Text = themeInfo.icon .. "  " .. themeInfo.name
            tName.TextColor3 = CurrentTheme.text
            tName.TextSize = 13
            tName.TextXAlignment = Enum.TextXAlignment.Left
            registerThemed("text", tName, "TextColor3")
            local activeLabel = Instance.new("TextLabel")
            activeLabel.Parent = tBtn
            activeLabel.BackgroundTransparency = 1
            activeLabel.Position = UDim2.new(0, 78, 0, 25)
            activeLabel.Size = UDim2.new(1, -130, 0, 18)
            activeLabel.Font = Enum.Font.Gotham
            activeLabel.Text = (CurrentThemeName == themeInfo.name) and "✅ Actif" or "Cliquer pour appliquer"
            activeLabel.TextColor3 = (CurrentThemeName == themeInfo.name) and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(90, 90, 90)
            activeLabel.TextSize = 10
            activeLabel.TextXAlignment = Enum.TextXAlignment.Left
            local applyBtnT = Instance.new("TextButton")
            applyBtnT.Parent = tBtn
            applyBtnT.BackgroundColor3 = (CurrentThemeName == themeInfo.name) and Color3.fromRGB(40, 80, 50) or Color3.fromRGB(50, 50, 60)
            applyBtnT.Position = UDim2.new(1, -65, 0.5, -12)
            applyBtnT.Size = UDim2.new(0, 55, 0, 24)
            applyBtnT.Font = Enum.Font.GothamSemibold
            applyBtnT.Text = (CurrentThemeName == themeInfo.name) and "✅" or "Appliquer"
            applyBtnT.TextColor3 = Color3.fromRGB(200, 200, 200)
            applyBtnT.TextSize = 10
            makeCorner(applyBtnT, 5)
            themeButtons[themeInfo.name] = {btn = tBtn, activeLabel = activeLabel, applyBtn = applyBtnT}
            local thisThemeName = themeInfo.name
            local function applyThisTh()
                applyTheme(thisThemeName, 0.5)
                updateAllThemeButtons()
            end
            tBtn.MouseButton1Click:Connect(applyThisTh)
            applyBtnT.MouseButton1Click:Connect(applyThisTh)
            tBtn.MouseEnter:Connect(function() tween(tBtn, {BackgroundColor3 = CurrentTheme.hoverBtn}, 0.15) end)
            tBtn.MouseLeave:Connect(function() tween(tBtn, {BackgroundColor3 = CurrentTheme.card}, 0.15) end)
            themeOrder = themeOrder + 1
        end
        local Sep = Instance.new("Frame")
        Sep.Parent = SFrame
        Sep.BackgroundColor3 = CurrentTheme.separator
        Sep.Size = UDim2.new(0.9, 0, 0, 1)
        Sep.BorderSizePixel = 0
        Sep.LayoutOrder = themeOrder
        registerThemed("separator", Sep)
        themeOrder = themeOrder + 1
        local TransLabel = Instance.new("TextLabel")
        TransLabel.Parent = SFrame
        TransLabel.BackgroundTransparency = 1
        TransLabel.Size = UDim2.new(1, -10, 0, 22)
        TransLabel.Font = Enum.Font.GothamBold
        TransLabel.Text = "🔍 Transparence du menu"
        TransLabel.TextColor3 = CurrentTheme.textDim
        TransLabel.TextSize = 13
        TransLabel.TextXAlignment = Enum.TextXAlignment.Left
        TransLabel.LayoutOrder = themeOrder
        registerThemed("textDim", TransLabel, "TextColor3")
        themeOrder = themeOrder + 1
        local SliderContainer = Instance.new("Frame")
        SliderContainer.Parent = SFrame
        SliderContainer.BackgroundColor3 = CurrentTheme.card
        SliderContainer.Size = UDim2.new(1, -10, 0, 80)
        SliderContainer.LayoutOrder = themeOrder
        makeCorner(SliderContainer, 8)
        makeStroke(SliderContainer, CurrentTheme.strokeLight, 1, "strokeLight")
        registerThemed("card", SliderContainer)
        local OpaqueLabel = Instance.new("TextLabel")
        OpaqueLabel.Parent = SliderContainer
        OpaqueLabel.BackgroundTransparency = 1
        OpaqueLabel.Position = UDim2.new(0, 15, 0, 8)
        OpaqueLabel.Size = UDim2.new(0, 60, 0, 16)
        OpaqueLabel.Font = Enum.Font.GothamSemibold
        OpaqueLabel.Text = "Opaque"
        OpaqueLabel.TextColor3 = CurrentTheme.textDim
        OpaqueLabel.TextSize = 10
        OpaqueLabel.TextXAlignment = Enum.TextXAlignment.Left
        registerThemed("textDim", OpaqueLabel, "TextColor3")
        local TransparentLabel = Instance.new("TextLabel")
        TransparentLabel.Parent = SliderContainer
        TransparentLabel.BackgroundTransparency = 1
        TransparentLabel.Position = UDim2.new(1, -75, 0, 8)
        TransparentLabel.Size = UDim2.new(0, 60, 0, 16)
        TransparentLabel.Font = Enum.Font.GothamSemibold
        TransparentLabel.Text = "Transparent"
        TransparentLabel.TextColor3 = CurrentTheme.textDim
        TransparentLabel.TextSize = 10
        TransparentLabel.TextXAlignment = Enum.TextXAlignment.Right
        registerThemed("textDim", TransparentLabel, "TextColor3")
        local TransValue = Instance.new("TextLabel")
        TransValue.Parent = SliderContainer
        TransValue.BackgroundTransparency = 1
        TransValue.Position = UDim2.new(0, 0, 0, 55)
        TransValue.Size = UDim2.new(1, 0, 0, 18)
        TransValue.Font = Enum.Font.GothamBold
        TransValue.Text = tostring(math.floor(CurrentTransparency * 100)) .. "%"
        TransValue.TextColor3 = CurrentTheme.accent
        TransValue.TextSize = 12
        registerThemed("accent", TransValue, "TextColor3")
        local SliderTrack = Instance.new("Frame")
        SliderTrack.Parent = SliderContainer
        SliderTrack.BackgroundColor3 = CurrentTheme.cardInner
        SliderTrack.Position = UDim2.new(0, 15, 0, 30)
        SliderTrack.Size = UDim2.new(1, -30, 0, 16)
        makeCorner(SliderTrack, 8)
        registerThemed("cardInner", SliderTrack)
        local SliderFill = Instance.new("Frame")
        SliderFill.Parent = SliderTrack
        SliderFill.BackgroundColor3 = CurrentTheme.accent
        SliderFill.Size = UDim2.new(CurrentTransparency, 0, 1, 0)
        makeCorner(SliderFill, 8)
        registerThemed("accent", SliderFill)
        local SliderKnob = Instance.new("Frame")
        SliderKnob.Parent = SliderTrack
        SliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        SliderKnob.Position = UDim2.new(CurrentTransparency, -10, 0.5, -10)
        SliderKnob.Size = UDim2.new(0, 20, 0, 20)
        SliderKnob.ZIndex = 5
        makeCorner(SliderKnob, 10)
        makeStroke(SliderKnob, CurrentTheme.stroke, 2, "stroke")
        local KnobCenter = Instance.new("Frame")
        KnobCenter.Parent = SliderKnob
        KnobCenter.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
        KnobCenter.Position = UDim2.new(0.5, -4, 0.5, -4)
        KnobCenter.Size = UDim2.new(0, 8, 0, 8)
        KnobCenter.ZIndex = 6
        makeCorner(KnobCenter, 4)
        local draggingSlider = false
        local function updateSlider(inputPos)
            local trackAbsPos = SliderTrack.AbsolutePosition.X
            local trackAbsSize = SliderTrack.AbsoluteSize.X
            local relativeX = math.clamp((inputPos.X - trackAbsPos) / trackAbsSize, 0, 1)
            CurrentTransparency = relativeX
            SliderFill.Size = UDim2.new(relativeX, 0, 1, 0)
            SliderKnob.Position = UDim2.new(relativeX, -10, 0.5, -10)
            TransValue.Text = tostring(math.floor(relativeX * 100)) .. "%"
            applyTransparency(relativeX)
        end
        SliderTrack.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = true
                MainContainer.Draggable = false
                updateSlider(input.Position)
            end
        end)
        SliderKnob.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                draggingSlider = true
                MainContainer.Draggable = false
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if draggingSlider and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                updateSlider(input.Position)
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if draggingSlider then
                    draggingSlider = false
                    MainContainer.Draggable = true
                end
            end
        end)
    end

    local function updateSidebarHighlight_inner(activeName)
        for name, btn in pairs(sidebarButtons) do
            if name == activeName then
                tween(btn, {BackgroundColor3 = CurrentTheme.sidebarActive}, 0.2)
                btn.TextColor3 = CurrentTheme.accent
            else
                tween(btn, {BackgroundColor3 = CurrentTheme.sidebarBtn}, 0.2)
                btn.TextColor3 = CurrentTheme.textDim
            end
        end
    end

    function updateSidebarHighlight(name)
        updateSidebarHighlight_inner(name)
    end

    local function createSidebarButton(name, icon, order, callback)
        local btn = Instance.new("TextButton")
        btn.Name = "Side_" .. name
        btn.Parent = Sidebar
        btn.BackgroundColor3 = CurrentTheme.sidebarBtn
        btn.Position = UDim2.new(0, 8, 0, 10 + (order * 44))
        btn.Size = UDim2.new(1, -16, 0, 38)
        btn.Font = Enum.Font.GothamBold
        btn.Text = icon .. " " .. name
        btn.TextColor3 = CurrentTheme.textDim
        btn.TextSize = 11
        btn.AutoButtonColor = false
        makeCorner(btn, 6)
        registerThemed("sidebarBtn", btn)
        registerThemed("textDim", btn, "TextColor3")
        btn.MouseEnter:Connect(function()
            if currentPage ~= name then tween(btn, {BackgroundColor3 = CurrentTheme.hoverBtn}, 0.15) end
        end)
        btn.MouseLeave:Connect(function()
            if currentPage ~= name then tween(btn, {BackgroundColor3 = CurrentTheme.sidebarBtn}, 0.15) end
        end)
        btn.MouseButton1Click:Connect(function()
            currentPage = name
            SettingsOpen = false
            updateSidebarHighlight_inner(name)
            callback()
        end)
        sidebarButtons[name] = btn
    end

    createSidebarButton("Home", "🏠", 0, buildGUI1)
    createSidebarButton("Teleport", "🔀", 1, buildGUI2)
    createSidebarButton("Auto", "⌨️", 2, buildGUI3)
    createSidebarButton("Misc", "🔧", 3, buildGUI4)

    SettingsBtn.MouseButton1Click:Connect(function()
        if SettingsOpen then
            SettingsOpen = false
            if currentPage == "Home" then buildGUI1()
            elseif currentPage == "Teleport" then buildGUI2()
            elseif currentPage == "Auto" then buildGUI3()
            elseif currentPage == "Misc" then buildGUI4()
            else buildGUI1() end
            updateSidebarHighlight_inner(currentPage)
        else
            SettingsOpen = true
            for _, btn in pairs(sidebarButtons) do
                tween(btn, {BackgroundColor3 = CurrentTheme.sidebarBtn}, 0.2)
                btn.TextColor3 = CurrentTheme.textDim
            end
            buildGUI5()
        end
    end)

    currentPage = "Home"
    updateSidebarHighlight_inner("Home")
    buildGUI1()
end
