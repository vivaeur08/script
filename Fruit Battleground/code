local function getHoldTimeForKey(keyStr)
    keyStr = string.upper(tostring(keyStr))
    if CustomHoldTimes[keyStr] and CustomHoldTimes[keyStr] > 0 then return CustomHoldTimes[keyStr] end
    return KeybindHoldTime
end

local function simulateKeyAndClick(kc, keyStr)
    local clickHold = getHoldTimeForKey(keyStr or "")
    VirtualInputManager:SendKeyEvent(true, kc, false, game)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    task.wait(clickHold)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
