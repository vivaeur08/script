        if SettingsOpen then SettingsOpen = false
            if cP == "Home" then bG1() elseif cP == "Teleport" then bG2() elseif cP == "Auto" then bG3() elseif cP == "Misc" then bG4() elseif cP == "Stats" then bG6() else bG1() end uSHi(cP)
        else SettingsOpen = true for _, b in pairs(sB) do tween(b, {BackgroundColor3=CurrentTheme.sidebarBtn}, 0.2) b.TextColor3 = CurrentTheme.textDim end bG5() end
    end)

    cP = "Home" uSHi("Home") bG1()
