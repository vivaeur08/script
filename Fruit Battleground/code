        local function refreshStats()
            pcall(function()
                local md = nil
                local debugInfo = "Scan:\n"

                local playerObj = Players:FindFirstChild(LocalPlayer.Name) or LocalPlayer
                debugInfo = debugInfo .. "Player: " .. LocalPlayer.Name .. "\n"

                md = playerObj:FindFirstChild("MAIN_DATA")
                if md then debugInfo = debugInfo .. "✅ Main_Data trouvé dans Player\n"
                else
                    for _, child in ipairs(playerObj:GetChildren()) do
                        if string.find(string.lower(child.Name), "data") or string.find(string.lower(child.Name), "stat") or string.find(string.lower(child.Name), "save") then
                            debugInfo = debugInfo .. "📁 " .. child.Name .. " (" .. child.ClassName .. ")\n"
                        end
                    end
                    debugInfo = debugInfo .. "❌ Main_Data non trouvé\n"

                    local ls = playerObj:FindFirstChild("leaderstats")
                    if ls then
                        debugInfo = debugInfo .. "📊 leaderstats trouvé\n"
                        for _, c in ipairs(ls:GetChildren()) do
                            debugInfo = debugInfo .. "  → " .. c.Name .. ": " .. tostring(c.Value) .. "\n"
                        end
                    end
                end

                if md then
                    local gems = md:FindFirstChild("Gems")
                    if gems then
                        gemsLabel.Text = "💎  Gems : " .. tostring(gems.Value)
                        debugInfo = debugInfo .. "Gems: " .. tostring(gems.Value) .. "\n"
                    else
                        gemsLabel.Text = "💎  Gems : N/A"
                        debugInfo = debugInfo .. "❌ Gems non trouvé\n"
                        for _, c in ipairs(md:GetChildren()) do
                            debugInfo = debugInfo .. "  📂 " .. c.Name .. " (" .. c.ClassName .. ")"
                            pcall(function() debugInfo = debugInfo .. " = " .. tostring(c.Value) end)
                            debugInfo = debugInfo .. "\n"
                        end
                    end

                    local titles = md:FindFirstChild("Titles")
                    if titles then
                        local count = #titles:GetChildren()
                        titlesLabel.Text = "🏆  Nombre de Titres : " .. tostring(count)
                    else titlesLabel.Text = "🏆  Titres : N/A" end

                    local kaido = md:FindFirstChild("KaidoKills")
                    if kaido then kaidoLabel.Text = "🐉  Kaido Kills : " .. tostring(kaido.Value) else kaidoLabel.Text = "🐉  Kaido Kills : N/A" end

                    local kata = md:FindFirstChild("KatakuriKills")
                    if kata then kataLabel.Text = "🍩  Katakuri Kills : " .. tostring(kata.Value) else kataLabel.Text = "🍩  Katakuri Kills : N/A" end

                    local bk = md:FindFirstChild("BossKills")
                    if bk then bossLabel.Text = "⚔️  Total Boss Kills : " .. tostring(bk.Value) else bossLabel.Text = "⚔️  Boss Kills : N/A" end

                    local slots = md:FindFirstChild("Slots")
                    if slots then slotsLabel.Text = "  📦  Slots : " .. tostring(slots.Value) else slotsLabel.Text = "  📦  Slots : N/A" end

                    for _, child in ipairs(spinScroll:GetChildren()) do
                        if child:IsA("TextLabel") then child:Destroy() end
                    end

                    local spinHist = md:FindFirstChild("SpinHistory")
                    if spinHist then
                        local order = 0
                        for _, spinEntry in ipairs(spinHist:GetChildren()) do
                            local entryLabel = Instance.new("TextLabel")
                            entryLabel.Parent = spinScroll
                            entryLabel.BackgroundColor3 = CurrentTheme.card
                            entryLabel.Size = UDim2.new(1,-6,0,26)
                            entryLabel.Font = Enum.Font.GothamSemibold
                            entryLabel.TextSize = 11
                            entryLabel.TextXAlignment = Enum.TextXAlignment.Left
                            entryLabel.LayoutOrder = order
                            makeCorner(entryLabel, 6)
                            registerThemed("card", entryLabel)

                            local val = ""
                            pcall(function()
                                if spinEntry:IsA("StringValue") or spinEntry:IsA("IntValue") or spinEntry:IsA("NumberValue") or spinEntry:IsA("BoolValue") then
                                    val = tostring(spinEntry.Value)
                                end
                            end)

                            entryLabel.Text = "  🎰 " .. spinEntry.Name .. (val ~= "" and (" : " .. val) or "")
                            entryLabel.TextColor3 = CurrentTheme.textDim
                            registerThemed("textDim", entryLabel, "TextColor3")
                            order = order + 1
                        end
                        if order == 0 then
                            local noSpin = Instance.new("TextLabel") noSpin.Parent = spinScroll noSpin.BackgroundTransparency = 1 noSpin.Size = UDim2.new(1,-6,0,24) noSpin.Font = Enum.Font.Gotham noSpin.Text = "Aucun spin enregistré" noSpin.TextColor3 = Color3.fromRGB(90,90,100) noSpin.TextSize = 10
                        end
                    else
                        local noSpin = Instance.new("TextLabel") noSpin.Parent = spinScroll noSpin.BackgroundTransparency = 1 noSpin.Size = UDim2.new(1,-6,0,24) noSpin.Font = Enum.Font.Gotham noSpin.Text = "SpinHistory introuvable" noSpin.TextColor3 = Color3.fromRGB(90,90,100) noSpin.TextSize = 10
                    end
                else
                    gemsLabel.Text = "💎  Gems : N/A (Main_Data introuvable)"
                    titlesLabel.Text = "🏆  Titres : N/A"
                    kaidoLabel.Text = "🐉  Kaido : N/A"
                    kataLabel.Text = "🍩  Katakuri : N/A"
                    bossLabel.Text = "⚔️  Boss : N/A"
                    slotsLabel.Text = "  📦  Slots : N/A"
                end

                debugLabel.Text = "  🔍 " .. debugInfo
            end)
        end

        refreshStats()

        task.spawn(function()
            while G6 and G6.Parent do
                refreshStats()
                task.wait(3)
            end
        end)
    end

    local function uSHi(an) for n, b in pairs(sB) do if n == an then tween(b, {BackgroundColor3=CurrentTheme.sidebarActive}, 0.2) b.TextColor3 = CurrentTheme.accent else tween(b, {BackgroundColor3=CurrentTheme.sidebarBtn}, 0.2) b.TextColor3 = CurrentTheme.textDim end end end
    function uSH(n) uSHi(n) end

    local function cSB(n, ic, o, cb)
        local b = Instance.new("TextButton") b.Name = "S_"..n b.Parent = SDr b.BackgroundColor3 = CurrentTheme.sidebarBtn b.Position = UDim2.new(0,8,0,12+(o*46)) b.Size = UDim2.new(1,-16,0,40) b.Font = Enum.Font.GothamBold b.Text = ic.."  "..n b.TextColor3 = CurrentTheme.textDim b.TextSize = 11 b.AutoButtonColor = false makeCorner(b, 8) registerThemed("sidebarBtn", b) registerThemed("textDim", b, "TextColor3")
        b.MouseEnter:Connect(function() if cP ~= n then tween(b, {BackgroundColor3=CurrentTheme.hoverBtn}, 0.2) end end)
        b.MouseLeave:Connect(function() if cP ~= n then tween(b, {BackgroundColor3=CurrentTheme.sidebarBtn}, 0.2) end end)
        b.MouseButton1Click:Connect(function() cP = n SettingsOpen = false uSHi(n) cb() end)
        sB[n] = b
    end

    cSB("Home", "🏠", 0, bG1) cSB("Teleport", "🔀", 1, bG2) cSB("Auto", "⌨️", 2, bG3) cSB("Misc", "🔧", 3, bG4) cSB("Stats", "📊", 4, bG6)

