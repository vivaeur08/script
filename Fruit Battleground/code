local function getAllSlotsInfo(playerName)
    local si={}
    pcall(function()
        local p=Players:FindFirstChild(playerName)
        if p then
            local md=p:FindFirstChild("MAIN_DATA")
            if md then
                local slots=md:FindFirstChild("Slots")
                if slots then
                    for _,entry in ipairs(slots:GetChildren()) do
                        local num=tonumber(entry.Name)
                        if num then
                            local fruitName=nil
                            if entry:IsA("StringValue") then
                                fruitName=entry.Value
                            else
                                for _,child in ipairs(entry:GetChildren()) do
                                    if child:IsA("StringValue") then
                                        fruitName=child.Value
                                        break
                                    end
                                end
                            end
                            if fruitName and fruitName~="" then
                                table.insert(si,{slot=num,fruit=fruitName})
                            end
                        end
                    end
                end
            end
        end
    end)
    table.sort(si,function(a,b) return a.slot<b.slot end)
    return si
end

local function getPlayerCurrentSlot(playerName)
    local slotValue=nil
    pcall(function()
        local p=Players:FindFirstChild(playerName)
        if p then
            local md=p:FindFirstChild("MAIN_DATA")
            if md then
                local slotObj=md:FindFirstChild("Slot")
                if slotObj then
                    if slotObj:IsA("NumberValue") or slotObj:IsA("IntValue") or slotObj:IsA("StringValue") then
                        slotValue=tostring(slotObj.Value)
                    else
                        for _,child in ipairs(slotObj:GetChildren()) do
                            if child:IsA("NumberValue") or child:IsA("IntValue") or child:IsA("StringValue") then
                                slotValue=tostring(child.Value)
                                break
                            end
                        end
                    end
                end
            end
        end
    end)
    return slotValue
end

local function getPlayerFruitFromSlot(playerName,slotValue)
    local fruitName=nil
    pcall(function()
        local p=Players:FindFirstChild(playerName)
        if p then
            local md=p:FindFirstChild("MAIN_DATA")
            if md then
                local slotsFolder=md:FindFirstChild("Slots")
                if slotsFolder then
                    local slotEntry=slotsFolder:FindFirstChild(tostring(slotValue))
                    if slotEntry then
                        if slotEntry:IsA("StringValue") then
                            fruitName=slotEntry.Value
                        else
                            for _,child in ipairs(slotEntry:GetChildren()) do
                                if child:IsA("StringValue") then
                                    fruitName=child.Value
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    return fruitName
end

local function getPlayerFruitLevel(playerName,fruitName)
    local level=nil
    pcall(function()
        local p=Players:FindFirstChild(playerName)
        if p then
            local md=p:FindFirstChild("MAIN_DATA")
            if md then
                local fruitsFolder=md:FindFirstChild("Fruits")
                if fruitsFolder then
                    local fruitEntry=fruitsFolder:FindFirstChild(fruitName)
                    if fruitEntry then
                        local lvlObj=fruitEntry:FindFirstChild("Level")
                        if lvlObj then
                            if lvlObj:IsA("NumberValue") or lvlObj:IsA("IntValue") then
                                level=lvlObj.Value
                            else
                                for _,child in ipairs(lvlObj:GetChildren()) do
                                    if child:IsA("NumberValue") or child:IsA("IntValue") then
                                        level=child.Value
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
    return level
end

local function getPlayerCurrentFruit(playerName)
    local slotVal=getPlayerCurrentSlot(playerName)
    if not slotVal then return nil,nil end
    local fruitName=getPlayerFruitFromSlot(playerName,slotVal)
    if not fruitName then return nil,nil end
    return fruitName,getPlayerFruitLevel(playerName,fruitName)
end

