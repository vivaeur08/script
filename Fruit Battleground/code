local function registerThemed(category, element, property)
    table.insert(ThemedElements[category], {element = element, property = property or "BackgroundColor3"})
end

local SETTINGS_FOLDER = "FruitHUB"
local SETTINGS_FILE = SETTINGS_FOLDER .. "/settings.json"

local function saveSettings()
    pcall(function()
        if not isfolder(SETTINGS_FOLDER) then
            makefolder(SETTINGS_FOLDER)
        end
        local themeToSave = "Noir & Gris"
        if CurrentThemeName and type(CurrentThemeName) == "string" and Themes[CurrentThemeName] then
            themeToSave = CurrentThemeName
        end
        local data = {
            theme = themeToSave,
            transparency = CurrentTransparency or 0
        }
        writefile(SETTINGS_FILE, HttpService:JSONEncode(data))
    end)
end

local function loadSettings()
    local success, result = pcall(function()
        if isfile(SETTINGS_FILE) then
            local raw = readfile(SETTINGS_FILE)
            return HttpService:JSONDecode(raw)
        end
        return nil
    end)
    if success and result then
        return result
    end
    return nil
end

local savedSettings = loadSettings()

if savedSettings then
    if savedSettings.theme and type(savedSettings.theme) == "string" and Themes[savedSettings.theme] then
        CurrentThemeName = savedSettings.theme
        CurrentTheme = Themes[CurrentThemeName]
    end
    if savedSettings.transparency and type(savedSettings.transparency) == "number" then
        CurrentTransparency = math.clamp(savedSettings.transparency, 0, 1)
    end
else
    saveSettings()
end

local function applyTheme(themeName, duration)
    duration = duration or 0.4
    if not themeName or not Themes[themeName] then return end
    CurrentThemeName = themeName
    CurrentTheme = Themes[themeName]
    for category, elements in pairs(ThemedElements) do
        local color = CurrentTheme[category]
        if color then
            for _, data in ipairs(elements) do
                if data.element and data.element.Parent then
                    local props = {}
                    props[data.property] = color
                    TweenService:Create(data.element, TweenInfo.new(duration, Enum.EasingStyle.Quad), props):Play()
                end
            end
        end
    end
    task.delay(0.1, function()
        saveSettings()
    end)
end

local function applyTransparency(value)
    CurrentTransparency = math.clamp(value, 0, 1)
    for _, data in ipairs(ThemedElements.bg) do
        if data.element and data.element.Parent and data.property == "BackgroundColor3" then
            TweenService:Create(data.element, TweenInfo.new(0.2), {BackgroundTransparency = value}):Play()
        end
    end
    for _, data in ipairs(ThemedElements.content) do
        if data.element and data.element.Parent and data.property == "BackgroundColor3" then
            TweenService:Create(data.element, TweenInfo.new(0.2), {BackgroundTransparency = value * 0.8}):Play()
        end
    end
    for _, data in ipairs(ThemedElements.sidebar) do
        if data.element and data.element.Parent and data.property == "BackgroundColor3" then
            TweenService:Create(data.element, TweenInfo.new(0.2), {BackgroundTransparency = value * 0.7}):Play()
        end
    end
    for _, data in ipairs(ThemedElements.titleBar) do
        if data.element and data.element.Parent and data.property == "BackgroundColor3" then
            TweenService:Create(data.element, TweenInfo.new(0.2), {BackgroundTransparency = value * 0.5}):Play()
        end
    end
    for _, data in ipairs(ThemedElements.card) do
        if data.element and data.element.Parent and data.property == "BackgroundColor3" then
            TweenService:Create(data.element, TweenInfo.new(0.2), {BackgroundTransparency = value * 0.6}):Play()
        end
    end
    task.delay(0.1, function()
        saveSettings()
    end)
end

