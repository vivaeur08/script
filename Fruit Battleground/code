    VirtualInputManager:SendKeyEvent(true, kc, false, game)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 0)
    task.wait(holdTime)
    VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    VirtualInputManager:SendKeyEvent(false, kc, false, game)
end

local function sendWebhook(message)
    if WebhookURL == "" or not WebhookURL or #WebhookURL < 20 then return end
    if WebhookCooldown then return end
    WebhookCooldown = true
    pcall(function()
        local data = HttpService:JSONEncode({content = message})
        local req = (syn and syn.request) or (http and http.request) or http_request or request
        if req then
            req({Url = WebhookURL, Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = data})
        end
    end)
    task.delay(3, function() WebhookCooldown = false end)
end

local function getCurrentLevel()
    local lvlNum = nil
    local lvlText = nil
    pcall(function()
        local pg = LocalPlayer:FindFirstChild("PlayerGui")
        if not pg then return end
        local ui = pg:FindFirstChild("UI")
        if not ui then return end
        local hud = ui:FindFirstChild("HUD")
        if not hud then return end
        for _, child in ipairs(hud:GetChildren()) do
            if child.Name == "Level" and (child:IsA("TextLabel") or child:IsA("TextButton")) then
                lvlText = child.Text
                break
            end
        end
        if not lvlText then
            for _, desc in ipairs(hud:GetDescendants()) do
                if desc.Name == "Level" and (desc:IsA("TextLabel") or desc:IsA("TextButton")) then
                    lvlText = desc.Text
                    break
                end
            end
        end
    end)

    if lvlText and lvlText ~= "" then
        local num = tonumber(string.match(lvlText, "%d+"))
        if num then lvlNum = num end
    end

    return lvlNum, lvlText
end

